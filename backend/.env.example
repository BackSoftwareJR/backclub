# Google OAuth (integrazione calendario freelance)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/api/auth/google/callback"
GOOGLE_OAUTH_FRONTEND_REDIRECT="${APP_URL}/freelance/impostazioni"
GOOGLE_CALENDAR_SCOPES="https://www.googleapis.com/auth/calendar.events openid email profile"
GOOGLE_CALENDAR_SYNC_ENABLED=true

# Google SEO OAuth (Search Console - credenziali separate)
GOOGLE_SEO_CLIENT_ID=
GOOGLE_SEO_CLIENT_SECRET=
GOOGLE_SEO_REDIRECT_URI=

# N8N automazioni calendario e agenti workspace (lasciare N8N_ENABLED=false finché non hai un'istanza reale)
# N8N_WEBHOOK_URL: endpoint per inviare task all'orchestratore (POST con auth header)
# N8N_CALLBACK_AUTH_*: auth per webhook callbacks da N8N a /api/webhooks/n8n/*
N8N_ENABLED=false
N8N_WEBHOOK_BASE_URL=
N8N_WEBHOOK_URL=http://2.24.15.210:8000/api/v1/execute-agent
N8N_WEBHOOK_AUTH_HEADER=X-API-Key
N8N_WEBHOOK_AUTH_VALUE=
N8N_CALLBACK_AUTH_HEADER=X-Orchestrator-Auth
N8N_CALLBACK_AUTH_VALUE=
# URL base per i callback inviati all'orchestratore (se APP_URL non include /backend/public)
N8N_CALLBACK_BASE_URL=https://backclub.it/backend/public
# n8n Callback Receiver — orchestrator invia qui le callback CRM invece che direttamente
N8N_CRM_CALLBACK_PROXY_URL=https://n8n.srv1691601.hstgr.cloud/webhook/69069118-f267-4a90-b94c-e32003830893
N8N_START_TIMEOUT_SECONDS=30
# GitHub API (merge staging → main da WorkSpace)
GITHUB_TOKEN=
GITHUB_PUBLISH_BASE_BRANCH=main
GITHUB_PUBLISH_HEAD_BRANCH=staging

N8N_WEBHOOK_PUBLISH_PRODUCTION=
N8N_CALENDAR_CALL_WEBHOOK=webhook/backclub-calendar-call
N8N_WORKSPACE_AGENT_WEBHOOK=
N8N_WEBHOOK_SECRET=
# Must match orchestrator WEBHOOK_SECRET when using X-Orchestrator-Signature auth
ORCHESTRATOR_WEBHOOK_SECRET=

# Email inviti call calendario (produzione: credenziali SMTP valide per info@backclub.it)
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.tuoprovider.it
# MAIL_PORT=587
# MAIL_USERNAME=info@backclub.it
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

