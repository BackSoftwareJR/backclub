DB_MARKETING_PORT=3306
DB_MARKETING_DATABASE=backclub_marketing
DB_MARKETING_USERNAME=root
DB_MARKETING_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
